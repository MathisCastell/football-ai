# Football.AI - Configuration
#
# Copie ce fichier en .env et configure tes cles :
#   cp .env.example .env
#
# ── API Football (optionnel) ──
# Inscription gratuite : https://www.football-data.org/
# Sans cle = donnees de demonstration generees automatiquement.
FOOTBALL_API_KEY=ta_cle_api_ici

# ── Bot Discord ──
# 1. Va sur https://discord.com/developers/applications
# 2. Cree une application > Bot > copie le token
# 3. Active "Message Content Intent" dans Privileged Gateway Intents
# 4. Invite le bot : OAuth2 > URL Generator > scopes: bot + applications.commands
#    Permissions: Send Messages, Embed Links, Use Slash Commands
DISCORD_TOKEN=ton_token_discord_ici
